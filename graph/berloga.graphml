        <y:UMLNoteNode>
          <y:Geometry height="434.2448219178083" width="648.3964674510371" x="-88.00436479779023" y="-226.78654118827149"/>
          <y:Fill color="#FFCC00" transparent="false"/>
          <y:BorderStyle color="#000000" type="line" width="1.0"/>
          <y:NodeLabel alignment="left" autoSizePolicy="content" fontFamily="Consolas" fontSize="12" fontStyle="plain" hasBackgroundColor="false" hasLineColor="false" height="409.09375" horizontalTextPosition="center" iconTextGap="4" modelName="internal" modelPosition="tl" textColor="#000000" verticalTextPosition="bottom" visible="true" width="579.982421875" x="4.0" xml:space="preserve" y="4.0">MAIN INIT


HSMRobot::NetworkError res;
	
const char *cmd_host = "127.0.0.1", *cmd_port = "5555";
const char *tel_host = "0.0.0.0", *tel_port = "5600", *tel_proto = "tcp";
	
if (getenv("CMD_HOST")) {
    cmd_host = getenv("CMD_HOST");
}
if (getenv("CMD_PORT")) {
    cmd_port = getenv("CMD_PORT");
}
if (getenv("TEL_HOST")) {
    tel_host = getenv("TEL_HOST");
}
if (getenv("TEL_PORT")) {
    tel_port = getenv("TEL_PORT");
}
if (getenv("PROTO")) {
    tel_proto = getenv("PROTO");
}

res = robot.initialize(cmd_host, cmd_port, tel_host, tel_port, tel_proto, CONNECTION_TIMEOUT);
if (res != HSMRobot::networkOK) {
    printf("Robot init error: %d\n", res);
    return 1;
}</y:NodeLabel>
